# ========================================
# SIAME 2026 - Variables de Entorno Producción
# ========================================
# Copia este archivo a .env.production y actualiza los valores marcados con [CAMBIAR]
#
# Para generar NEXTAUTH_SECRET seguro, ejecuta:
# openssl rand -base64 32
# ========================================

# Base de datos PostgreSQL (mismo servidor)
DATABASE_URL="postgresql://postgres:[PASSWORD_DB]@localhost:5432/siame2026"
# Para GitHub Actions (workflow security-operations), definir mismo valor en Secret:
# SECURITY_DATABASE_URL
SECURITY_DATABASE_URL="postgresql://postgres:[PASSWORD_DB]@localhost:5432/siame2026"

# NextAuth.js Configuration
# Genera un secreto único con: openssl rand -base64 32
NEXTAUTH_SECRET="[GENERAR_NUEVO_SECRETO_ALEATORIO]"
# Para GitHub Actions (workflow security-operations), definir mismo valor en Secret:
# SECURITY_NEXTAUTH_SECRET
SECURITY_NEXTAUTH_SECRET="[GENERAR_NUEVO_SECRETO_ALEATORIO]"
# URL pública del sitio en producción (HTTPS)
NEXTAUTH_URL="https://[TU-DOMINIO-.COM]"

# Node.js Configuration
NODE_ENV=production
PORT=3000
NEXT_DISABLE_TURBO=true

# Azure Document Intelligence Configuration
# Reemplaza con tus credenciales de producción
AZURE_FORM_RECOGNIZER_ENDPOINT="https://[TU-RESOURCE].cognitiveservices.azure.com/"
AZURE_FORM_RECOGNIZER_KEY="[TU_API_KEY_PRODUCCION]"

# Security headers (CSP rollout)
# "report-only" para observar reportes sin bloquear
# "enforce" para aplicar bloqueo estricto
SECURITY_CSP_MODE="report-only"
# Solo habilitar en casos excepcionales de compatibilidad legacy
SECURITY_CSP_ALLOW_UNSAFE_EVAL="false"
# Lista explícita de hosts permitidos para mutaciones sensibles (coma-separado)
SECURITY_TRUSTED_HOSTS="localhost:3000,[TU-DOMINIO-.COM]"

# Sesiones activas simultáneas por usuario
AUTH_MAX_ACTIVE_SESSIONS="3"

# Tiempo máximo de inactividad de sesión (minutos)
AUTH_SESSION_IDLE_TIMEOUT_MINUTES="120"

# Retención de registros de sesiones (días) para limpieza
AUTH_SESSION_RETENTION_DAYS="30"

# Alertas de seguridad (ventana de observación)
SECURITY_ALERT_WINDOW_MINUTES="15"
SECURITY_ALERT_LOGIN_FAILED_THRESHOLD="20"
SECURITY_ALERT_SESSION_POLICY_THRESHOLD="10"
SECURITY_ALERT_IP_QUARANTINE_THRESHOLD="8"
SECURITY_ALERT_PASSWORD_CHANGE_FAILED_THRESHOLD="8"
SECURITY_ALERT_PASSWORD_CHANGE_BLOCKED_THRESHOLD="6"
SECURITY_ALERT_SIGNUP_BLOCKED_THRESHOLD="8"

# Cuarentena por IP agresiva (brute force distribuido)
AUTH_IP_QUARANTINE_THRESHOLD="80"
AUTH_IP_QUARANTINE_WINDOW_MINUTES="60"
AUTH_IP_UNBLOCK_DEFAULT_MINUTES="120"

# SLA de atención de incidentes de seguridad (minutos)
SECURITY_INCIDENT_SLA_HIGH_MINUTES="30"
SECURITY_INCIDENT_SLA_MEDIUM_MINUTES="120"

# Notificación de brechas SLA (Webhook)
SECURITY_INCIDENT_NOTIFY_WEBHOOK_URL=""
SECURITY_INCIDENT_NOTIFY_MIN_BREACH_COUNT="1"
SECURITY_INCIDENT_NOTIFY_COOLDOWN_MINUTES="30"
SECURITY_INCIDENT_NOTIFY_MAX_RETRIES="3"
SECURITY_INCIDENT_NOTIFY_TIMEOUT_MS="5000"

# Auditoría de dependencias
SECURITY_MAX_CRITICAL_VULNS="0"
SECURITY_MAX_HIGH_VULNS="999"

# Bloqueo de cuenta por intentos fallidos de login
AUTH_ACCOUNT_LOCK_THRESHOLD="5"
AUTH_ACCOUNT_LOCK_MINUTES="15"
